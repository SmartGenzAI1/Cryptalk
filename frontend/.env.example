# Development (local with Caddy gateway)
# The API client appends ?XTransformPort=BACKEND_PORT to all requests
NEXT_PUBLIC_BACKEND_PORT=8001

# Production (Vercel + Render)
# Set this to your Render backend URL — the API client will call it directly
# NEXT_PUBLIC_BACKEND_URL=https://cryptalk-backend.onrender.com

# No secrets on the frontend — all crypto is client-side
