# ────────────────────────────────────────────────────────────
# Cryptalk Frontend — Environment Configuration
# ────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.

# Backend port (used by the API client for XTransformPort routing)
BACKEND_PORT=8001

# App name (shown in UI)
NEXT_PUBLIC_APP_NAME=Cryptalk

# ── DEPLOYMENT NOTES ─────────────────────────────────────────
# 1. Set BACKEND_PORT to match your backend server port
# 2. In production, use a reverse proxy (Caddy/Nginx) to route
#    /api/* to the backend and serve the frontend from the root
# 3. No secrets needed on the frontend — all crypto happens
#    client-side and private keys never leave the browser
