# ────────────────────────────────────────────────────────────
# Cryptalk Backend — Environment Configuration
# ────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to git.

# Server
HOST=0.0.0.0
PORT=8001
DEBUG=False

# Database — SQLite path (use absolute path in production)
# For PostgreSQL: DB_PATH=postgresql://user:pass@localhost:5432/cryptalk
DB_PATH=./db/cryptalk.db

# ── SECRETS ──────────────────────────────────────────────────
# Generate a strong random string for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Or:
#   openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-64-char-string

# Session cookie
COOKIE_NAME=tc_session
COOKIE_MAX_AGE=2592000

# CORS — comma-separated list of allowed origins
# Production: https://yourdomain.com
CORS_ORIGINS=*

# ── DEPLOYMENT NOTES ─────────────────────────────────────────
# 1. Always set SESSION_SECRET to a random 64-char hex string
# 2. Set CORS_ORIGINS to your frontend domain in production
# 3. Use a persistent volume for DB_PATH if using SQLite
# 4. Put behind a reverse proxy (Caddy/Nginx) for TLS
# 5. Run with multiple workers: uvicorn app.main:asgi_app --workers 4
