# ── Cryptalk Backend Environment ──

# Server (Render sets PORT automatically)
PORT=8001
DEBUG=False

# ── Database ──
# Option 1: SQLite (local dev)
DB_PATH=./db/cryptalk.db

# Option 2: Supabase PostgreSQL (production)
# Get this from: Supabase Dashboard > Settings > Database > Connection string
# Format: postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# DATABASE_URL=postgresql+asyncpg://postgres:your-password@db.your-ref.supabase.co:5432/postgres

# ── SECRETS ──
# Generate: openssl rand -hex 32
SESSION_SECRET=

# Session cookie
COOKIE_NAME=tc_session
COOKIE_MAX_AGE=2592000

# CORS — your Vercel frontend URL in production
CORS_ORIGINS=*
