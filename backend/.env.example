# ── Cryptalk Backend Environment ──
# Copy to .env for local dev. Set these in Render dashboard for production.

# Server (Render sets PORT automatically)
PORT=8001
DEBUG=False

# Database (Render uses a persistent disk)
DB_PATH=./db/cryptalk.db

# ── SECRETS ──
# Generate: openssl rand -hex 32
SESSION_SECRET=

# Session cookie
COOKIE_NAME=tc_session
COOKIE_MAX_AGE=2592000

# CORS — your Vercel frontend URL in production
# Local dev: * (all origins)
# Production: https://your-app.vercel.app
CORS_ORIGINS=*
