# ── Cryptalk Backend Environment ──
# Copy to .env for local dev. Set in Render dashboard for production.

PORT=8001
DEBUG=False

# Database
# Local: SQLite
DB_PATH=./db/cryptalk.db
# Production: Supabase PostgreSQL
# DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# ── SECRETS ──
# Generate: openssl rand -hex 32
SESSION_SECRET=

COOKIE_NAME=tc_session
COOKIE_MAX_AGE=2592000

# CORS — your Vercel frontend URL in production
CORS_ORIGINS=*

# ── Redis (Upstash free tier) ──
# For multi-process Socket.IO scaling + distributed rate limiting
# Get from: upstash.com → create Redis database
# REDIS_URL=redis://default:password@host.upstash.io:6379

# ── Sentry (free tier) ──
# For error tracking in production
# Get from: sentry.io → create project → FastAPI
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ── Supabase ──
# For file storage (images, documents)
# Get from: Supabase dashboard → Settings → API
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_KEY=eyJhbG...
